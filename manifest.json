{
  "manifest_version": 2,
  "name": "background-color-picker",
  "version": "1.0.2",
  "description": "Adds a color picker to adjust the body style background",
  "icons": {
    "48": "BYR_color_wheel.png",
    "96": "BYR_color_wheel.png"
  },
  "browser_action": {
    "default_icon": "BYR_color_wheel.png",
    "default_title": "Change Background"
  },
  "background": {
    "page": "background.html",
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "background-color-picker.js"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "{3d48fbda-2a1e-4d9e-a0a3-c0d3ab43b52f}"
    }
  },
  "addons": {
    "{3d48fbda-2a1e-4d9e-a0a3-c0d3ab43b52f}": {
      "updates": [
        {
          "version": "1.0.1",
          "update_link": "https://github.com/skillplants/background-color-picker",
          "applications": {
            "gecko": { "strict_min_version": "44" }
          }
        }
      ]
    }
  }
}
